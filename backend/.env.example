# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.example
#
# Yerel geliştirme ortamı için .env şablonu.
# Kendi ortamınız için bunu kopyalayıp adını ".env" yapın ve değerleri doldurun.
# ─────────────────────────────────────────────────────────────────────────────

# ── Uygulama ─────────────────────────────────────────────────────────────────
SECRET_KEY=super_gizli_whaletracker_anahtari_bunu_degistir

# ── Veritabanı ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://whale:whale_secret_2024@postgres:5432/whaletracker

# ── Dosya yükleme ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads

# ── Şifreleme (AES-256-GCM) ───────────────────────────────────────────────────
AES_FIELD_KEY=BURAYA_AES_ANAHTARINI_YAZ

# ── AI & Dış Servisler ────────────────────────────────────────────────────────
GEMINI_API_KEY=BURAYA_GEMINI_API_ANAHTARINI_YAZ
TWELVE_DATA_API_KEY=BURAYA_TWELVE_DATA_ANAHTARINI_YAZ
ETHERSCAN_API_KEY=BURAYA_ETHERSCAN_ANAHTARINI_YAZ
CRYPTOPANIC_API_KEY=BURAYA_CRYPTOPANIC_ANAHTARINI_YAZ

# ── Stripe Ödeme ──────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=BURAYA_STRIPE_PUBLISHABLE_KEY_YAZ
STRIPE_SECRET_KEY=BURAYA_STRIPE_SECRET_KEY_YAZ
STRIPE_WEBHOOK_SECRET=BURAYA_STRIPE_WEBHOOK_SECRET_YAZ
STRIPE_PRICE_ID=BURAYA_STRIPE_PRICE_ID_YAZ

# Başarılı/iptal ödeme sonrası yönlenme URL'i
FRONTEND_URL=http://localhost:3000

# ── E-posta Servisi ───────────────────────────────────────────────────────────
RESEND_API_KEY=BURAYA_RESEND_API_KEY_YAZ
