# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.production.example
#
# Sunucuya kopyala, adını .env.production yap ve TÜM değerleri doldur.
# Bu dosyayı GIT'E COMMIT ETME — .gitignore'a ekli olduğundan emin ol.
# ─────────────────────────────────────────────────────────────────────────────

# ── Uygulama ─────────────────────────────────────────────────────────────────
# En az 64 karakter, rastgele: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=BURAYA_GUCLU_BIR_SECRET_KEY_YAZ

# Production ortamını işaretler (FastAPI docs kapatır, SSL zorunlu kılar)
ENVIRONMENT=production

# ── Veritabanı ────────────────────────────────────────────────────────────────
POSTGRES_DB=whaletracker
POSTGRES_USER=whale
# Güçlü parola: openssl rand -base64 32
POSTGRES_PASSWORD=BURAYA_GUCLU_DB_PAROLASI_YAZ
DATABASE_URL=postgresql://whale:BURAYA_GUCLU_DB_PAROLASI_YAZ@postgres:5432/whaletracker

# ── Redis ─────────────────────────────────────────────────────────────────────
# Güçlü parola: openssl rand -base64 32
REDIS_PASSWORD=BURAYA_GUCLU_REDIS_PAROLASI_YAZ
REDIS_URL=redis://:BURAYA_GUCLU_REDIS_PAROLASI_YAZ@redis:6379/0

# ── CORS — domain adını gir ───────────────────────────────────────────────────
ALLOWED_ORIGINS=https://YOUR_DOMAIN.com,https://www.YOUR_DOMAIN.com

# ── Dosya yükleme ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads

# ── Şifreleme (AES-256-GCM) ───────────────────────────────────────────────────
# Yeni anahtar üret: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AES_FIELD_KEY=BURAYA_AES_ANAHTARINI_YAZ

# ── AI & Dış Servisler ────────────────────────────────────────────────────────
GEMINI_API_KEY=BURAYA_GEMINI_API_ANAHTARINI_YAZ
TWELVE_DATA_API_KEY=BURAYA_TWELVE_DATA_ANAHTARINI_YAZ
ETHERSCAN_API_KEY=BURAYA_ETHERSCAN_ANAHTARINI_YAZ
CRYPTOPANIC_API_KEY=BURAYA_CRYPTOPANIC_ANAHTARINI_YAZ

# ── Stripe Ödeme ──────────────────────────────────────────────────────────────
# Test:  sk_test_...  |  Canlı: sk_live_...
STRIPE_SECRET_KEY=BURAYA_STRIPE_SECRET_KEY_YAZ
# Stripe Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=BURAYA_STRIPE_WEBHOOK_SECRET_YAZ
# Stripe Dashboard → Products → Fiyat ID'si (aylık plan)
STRIPE_PRICE_ID=BURAYA_STRIPE_PRICE_ID_YAZ
# Başarılı/iptal ödeme sonrası yönlenme URL'i
FRONTEND_URL=https://YOUR_DOMAIN.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=BURAYA_GOOGLE_CLIENT_ID_YAZ

# ── E-posta (Gmail SMTP) ───────────────────────────────────────────────────────
# Gmail hesabı ve App Password (Uygulama Şifresi)
# App Password oluşturmak için: Google Hesap → Güvenlik → 2FA açık → Uygulama şifreleri
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=BURAYA_GMAIL_APP_PASSWORD_YAZ

# ── Railway + Vercel Deploy Notları ───────────────────────────────────────────
# Railway'de set etmeniz gereken ALLOWED_ORIGINS örneği:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.your-domain.com
#
# Vercel'de set etmeniz gereken frontend env değişkenleri:
# REACT_APP_API_URL=https://your-backend.railway.app
# REACT_APP_GOOGLE_CLIENT_ID=<yukarıdaki GOOGLE_CLIENT_ID ile aynı değer>
