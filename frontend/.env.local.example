# ── Backend API Bağlantısı ────────────────────────────────────────────────────
# Geliştirme ortamında boş bırakın (localhost:8000 kullanılır)
# Production (Vercel): Railway backend URL'inizi girin
REACT_APP_API_URL=http://localhost:8000

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console → Credentials → OAuth 2.0 Client ID
# Authorized JavaScript origins'e localhost:3000 ve Vercel URL'inizi ekleyin
REACT_APP_GOOGLE_CLIENT_ID=

# ── Analitik ──────────────────────────────────────────────────────────────────
REACT_APP_POSTHOG_KEY=phc_your_posthog_api_key_here
REACT_APP_POSTHOG_HOST=https://app.posthog.com
